# Build outputs — regenerated locally, never committed
output/
jobs/**/*.pdf

# Personal config — created by setup.py, never committed
user.yaml

# Personal career profile — written by /gather-background, never committed
markdown/background.md

# Application tracker — contains your real job history, never committed
tracker.csv

# Real job applications (001+) — demo entries (000_*) remain tracked
jobs/00[1-9]_*/
jobs/0[1-9][0-9]_*/
jobs/[1-9][0-9][0-9]_*/

# Personal signature image — user supplies their own
template/signature.png
jobs/**/signature.png

# Dashboard — generated by `make dashboard`, never committed
site/dashboard.html

# Claude Code local config — has machine-specific paths
.claude/settings.local.json
.claude/worktrees/

# Python
__pycache__/
*.pyc
.venv/

# macOS
.DS_Store
**/.DS_Store
