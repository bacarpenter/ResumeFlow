# Build outputs — regenerated locally, never committed
output/
jobs/**/*.pdf

# Personal config — created by setup.py, never committed
user.yaml

# Personal signature image — user supplies their own
template/signature.png
jobs/**/signature.png

# Dashboard — generated by `make dashboard`, never committed
site/dashboard.html

# Claude Code local config — has machine-specific paths
.claude/settings.local.json
.claude/worktrees/

# Python
__pycache__/
*.pyc
.venv/

# macOS
.DS_Store
**/.DS_Store
